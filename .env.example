# Aish Laundry App — LOCAL DEVELOPMENT environment template.
#
# Copy to `.env` and adjust. `.env` is git-ignored and MUST NEVER be committed:
# this repository is PUBLIC, and a committed secret is compromised the moment it
# is pushed — deletion is not remediation, rotation is.
#
# Every value below is a DEVELOPMENT PLACEHOLDER. None grants access to anything.
# Never reuse any of these values in a real environment.

# --- environment -------------------------------------------------------------
# Must be a development value. scripts/reset-dev-data.sh refuses to destroy data
# unless this is local/development/dev/testing/test.
APP_ENV=local
APP_DEBUG=true

# --- development PostgreSQL (infrastructure/docker-compose.dev.yml) ----------
# Port 55433, not 5432: an unrelated pre-existing container already holds the
# common ports on some development hosts. Loopback only.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=55433
DB_DATABASE=aish_laundry_dev
DB_USERNAME=aish_dev
DB_PASSWORD=aish_dev_password_not_secret

# --- development Redis -------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=56379
REDIS_PASSWORD=null

# --- notes -------------------------------------------------------------------
# No production host, no staging host, no VPS address, and no third-party
# provider credential belongs in this file or in `.env`. WhatsApp, payment, and
# map providers are owned by later canonical steps and are NOT configured here.
