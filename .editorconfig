# EditorConfig — Aish Laundry App
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[*.{yml,yaml,json,jsonc,md,markdown,html,css,js,ts}]
indent_style = space
indent_size = 2

[*.{py,sh,bash}]
indent_style = space
indent_size = 4

[*.md]
# Markdown uses trailing double-space as a hard line break.
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab

[*.{sha256,txt}]
insert_final_newline = true
trim_trailing_whitespace = true

[LICENSE]
insert_final_newline = true
