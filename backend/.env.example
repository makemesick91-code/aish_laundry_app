# Aish Laundry App — backend environment template.
#
# PLACEHOLDERS ONLY. This file is committed to a PUBLIC repository
# (AMENDMENT-0001, DEC-0016). It must never carry a real credential, a real
# host, a real token, or any customer datum. Copy it to `.env` locally and
# fill in local development values; `.env` is git-ignored and never committed.

APP_NAME="Aish Laundry App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=id

# Timestamps are STORED in UTC. config/app.php pins that deliberately and does
# NOT read a timezone from this file, so one deployment can never silently
# store local time while another stores UTC. Presentation is Asia/Jakarta;
# quiet hours and unclaimed-laundry aging use OUTLET local time, read from
# `outlets.timezone` (Rule 06 rule 11, Rule 08, Rule 10).

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- PostgreSQL (authoritative database; SQLite is never a substitute) -------
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=replace_with_local_database_name
DB_USERNAME=replace_with_local_username
DB_PASSWORD=CHANGEME_local_dev_only

# --- Redis (cache, queue, locks, rate limiting; never a system of record) ----
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
